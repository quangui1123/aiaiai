# Admin account (created on first startup)
ADMIN_EMAIL=admin@aiaiai.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# JWT secret — set a fixed value in production (otherwise sessions reset on restart)
JWT_SECRET=

# New user default quota in USD (-1 = unlimited for admin only)
DEFAULT_QUOTA=0.5

# Server
HOST=0.0.0.0
PORT=8000

# CORS: * for all origins, or comma-separated list
CORS_ORIGINS=*
